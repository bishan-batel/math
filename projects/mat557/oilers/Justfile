set allow-duplicate-variables := true

# set working-directory := "./../../../"

slides := "FirstTitle IntroNewtonsMethod NewtonsMethodSimplification NewtonComplex NewtonFractalIntroduction NewtonPrelimsFixedPoint"

default: playground

playground scene="Playground":
    @echo $(pwd)
    @uv run manimgl "{{ justfile_dir() }}/playground.py" {{ scene }}

@gl file="Slides.py" scene="":
    @uv run manimgl "{{ justfile_dir() }}/{{ file }}" {{ scene }}

@render slides=slides:
    @uv run manim-slides render --GL {{ justfile_dir() }}/Slides.py {{ slides }} --uhd

@renderm slides=slides:
    @uv run manim-slides render --GL {{ justfile_dir() }}/Slides.py {{ slides }} -m

@renderl slides=slides:
    @uv run manim-slides render --GL {{ justfile_dir() }}/Slides.py {{ slides }} -l

@convert slides=slides:
    @mkdir dist/
    @uv run manim-slides convert {{ slides }} ./dist/Slides.html --to=html

@present:
    @uv run manim-slides present {{ slides }}
